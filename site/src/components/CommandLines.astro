---
interface Props {
  commands: string[];
}

const { commands } = Astro.props;
---

<div class="command-lines">
  {commands.map((cmd) => (
    <div class="command-line" data-command={cmd}>
      <code>{cmd}</code>
      <button
        class="command-copy"
        aria-label={`Copy: ${cmd}`}
        data-copy={cmd}
      >
        <svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <svg class="icon-check" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </button>
    </div>
  ))}
</div>

<script>
  document.querySelectorAll('.command-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = (btn as HTMLElement).dataset.copy;
      if (!text) return;
      await navigator.clipboard.writeText(text);
      const iconCopy = btn.querySelector('.icon-copy') as HTMLElement;
      const iconCheck = btn.querySelector('.icon-check') as HTMLElement;
      iconCopy.style.display = 'none';
      iconCheck.style.display = 'block';
      setTimeout(() => {
        iconCopy.style.display = 'block';
        iconCheck.style.display = 'none';
      }, 1500);
    });
  });
</script>
