---
---

<starlight-theme-toggle class="sl-flex">
	<button class="theme-btn" data-theme-value="light" aria-label="Use light theme">
		<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="12" cy="12" r="5"></circle>
			<line x1="12" y1="1" x2="12" y2="3"></line>
			<line x1="12" y1="21" x2="12" y2="23"></line>
			<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
			<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
			<line x1="1" y1="12" x2="3" y2="12"></line>
			<line x1="21" y1="12" x2="23" y2="12"></line>
			<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
			<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
		</svg>
	</button>
	<button class="theme-btn" data-theme-value="dark" aria-label="Use dark theme">
		<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
		</svg>
	</button>
</starlight-theme-toggle>

{/* Inlined to avoid FOUC */}
<script is:inline>
	StarlightThemeProvider.updatePickers();
</script>

<script>
	/** Key in `localStorage` to store color theme preference at. */
	const storageKey = 'starlight-theme';

	type Theme = 'dark' | 'light';

	const parseTheme = (theme: unknown): Theme =>
		theme === 'light' ? 'light' : 'dark';

	const loadTheme = (): Theme =>
		parseTheme(typeof localStorage !== 'undefined' && localStorage.getItem(storageKey));

	function storeTheme(theme: Theme): void {
		if (typeof localStorage !== 'undefined') {
			localStorage.setItem(storageKey, theme);
		}
	}

	function applyTheme(theme: Theme): void {
		document.documentElement.dataset.theme = theme;
		storeTheme(theme);
		updateButtons(theme);
	}

	function updateButtons(theme: Theme): void {
		document.querySelectorAll('starlight-theme-toggle').forEach((toggle) => {
			toggle.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach((btn) => {
				const isActive = btn.dataset.themeValue === theme;
				btn.classList.toggle('active', isActive);
				btn.setAttribute('aria-pressed', String(isActive));
			});
		});
	}

	class StarlightThemeToggle extends HTMLElement {
		constructor() {
			super();
			const theme = loadTheme();
			applyTheme(theme);

			this.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach((btn) => {
				btn.addEventListener('click', () => {
					const newTheme = btn.dataset.themeValue as Theme;
					applyTheme(newTheme);
				});
			});
		}
	}
	customElements.define('starlight-theme-toggle', StarlightThemeToggle);
</script>

<style>
	starlight-theme-toggle {
		gap: 0.25rem;
		align-items: center;
	}

	.theme-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		border: 0;
		padding: 0.375rem;
		background: transparent;
		cursor: pointer;
		color: var(--sl-color-gray-3);
		border-radius: 0.5rem;
		transition: color 0.15s ease, background-color 0.15s ease;
	}

	.theme-btn:hover {
		color: var(--sl-color-text);
	}

	.theme-btn.active {
		color: var(--sl-color-text-accent);
	}

	.theme-btn svg {
		width: 1.25rem;
		height: 1.25rem;
	}
</style>
